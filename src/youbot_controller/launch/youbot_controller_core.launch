<launch>
    <!-- Параметры комнаты можно переопределить снаружи -->
    <arg name="room_width"  default="5.0"/>
    <arg name="room_height" default="5.0"/>
    <arg name="seed"        default="42"/>

    <!-- 1. Сначала генерируем комнату (препятствия/точки A,B,C в /room/*).
            room_generator выставляет ROS-параметры ДО старта контроллера. -->
    <include file="$(find youbot_controller)/launch/room_generator.launch">
        <arg name="room_width"  value="$(arg room_width)"/>
        <arg name="room_height" value="$(arg room_height)"/>
        <arg name="seed"        value="$(arg seed)"/>
    </include>

    <!-- 2. Узел визуализации пути + подписи A/B/C -->
    <node name="mission_viz" pkg="youbot_controller" type="visualization_node.py" output="screen"/>

    <!-- 3. Управляющий узел (читает /room/* при init_mission) -->
    <node name="youbot_controller" pkg="youbot_controller" type="youbot_controller.py" output="screen"/>
</launch>
