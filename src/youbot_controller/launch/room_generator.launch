<?xml version="1.0"?>
<launch>
  <!-- ====================================================================
       room_generator: строит комнату (n x m), сетку, точки A/B/C и
       виртуальные препятствия. Единственный источник истины о ПРЕПЯТСТВИЯХ.

       ВСЕ значения берутся из ЕДИНОГО файла:
         youbot_perception/config/mission_params.yaml
       (загружается в namespace /mission_config). Меняйте параметры ТАМ —
       здесь ничего править не нужно.
       ==================================================================== -->

  <!-- Загрузить центральный конфиг (если родительский launch ещё не загрузил). -->
  <rosparam ns="mission_config"
            command="load"
            file="$(find youbot_perception)/config/mission_params.yaml"/>

  <node name="room_generator" pkg="youbot_controller" type="room_generator.py"
        output="screen"/>
</launch>
