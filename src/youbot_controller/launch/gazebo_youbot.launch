<?xml version="1.0"?>
<launch>

  <!-- Запуск пустого мира Gazebo -->
  <include file="$(find gazebo_ros)/launch/empty_world.launch">
    <arg name="paused" value="false"/>
    <arg name="use_sim_time" value="true"/>
    <arg name="gui" value="true"/>
    <arg name="headless" value="false"/>
    <arg name="debug" value="false"/>
  </include>

  <!-- Загрузка URDF-описания робота из xacro -->
  <param name="robot_description" command="$(find xacro)/xacro $(find youbot_description)/robots/youbot.urdf.xacro"/>

  <!-- Спавн модели робота в симуляции -->
  <!-- Флаг -urdf указывает, что передаётся URDF-модель -->
  <node name="spawn_youbot" pkg="gazebo_ros" type="spawn_model"
        args="-urdf -param robot_description -x 0 -y 0 -z 0.1 -model youbot"
        output="screen"/>

  <!-- Загрузка параметров контроллеров: колёса, манипулятор, схват -->
  <rosparam file="$(find youbot_mecanum_controller)/config/velocity_controllers.yaml" command="load"/>

  <!-- Контроллеры для руки и схвата -->
  <rosparam>
    arm_controller:
      type: position_controllers/JointGroupPositionController
      joints:
        - arm_joint_1
        - arm_joint_2
        - arm_joint_3
        - arm_joint_4
        - arm_joint_5
    gripper_controller:
      type: position_controllers/JointGroupPositionController
      joints:
        - gripper_finger_joint_l
        - gripper_finger_joint_r
  </rosparam>

  <!-- Запуск контроллеров через controller_manager -->
  <!-- Здесь перечислены все контроллеры, которые будут активированы -->
  <node name="controller_spawner" pkg="controller_manager" type="spawner"
        args="
          joint_state_controller
          wheel_joint_fl_velocity_controller
          wheel_joint_fr_velocity_controller
          wheel_joint_bl_velocity_controller
          wheel_joint_br_velocity_controller
          arm_controller
          gripper_controller
        "
        output="screen"/>

</launch>