<?xml version="1.0"?>
<launch>
  <arg name="world" default="empty"/>
  <arg name="init_pos_x" default="0.0"/>
  <arg name="init_pos_y" default="0.0"/>
  <arg name="init_pos_z" default="0.1"/>
  <arg name="use_sim_time" default="true"/>
  <arg name="gui" default="true"/>
  <arg name="headless" default="false"/>

  <!-- Gazebo -->
  <include file="$(find gazebo_ros)/launch/$(arg world)_world.launch">
    <arg name="paused" value="false"/>
    <arg name="use_sim_time" value="$(arg use_sim_time)"/>
    <arg name="gui" value="$(arg gui)"/>
    <arg name="headless" value="$(arg headless)"/>
    <arg name="debug" value="false"/>
  </include>

  <!-- URDF -->
  <param name="robot_description" command="$(find xacro)/xacro '$(find youbot_description)/robots/youbot.urdf.xacro'"/>

  <!-- Спавн -->
  <node pkg="gazebo_ros" type="spawn_model" name="spawn_robot" respawn="false" output="screen"
    args="-param robot_description -urdf -x $(arg init_pos_x) -y $(arg init_pos_y) -z $(arg init_pos_z) -model youbot"/>

  <!-- joint_state_controller (оригинал) -->
  <include file="$(find youbot_gazebo_control)/launch/joint_state_controller.launch"/>

  <!-- Ваши собственные launch-файлы для контроллеров руки и схвата -->
  <!-- Они загружают параметры из ваших YAML и запускают контроллеры без префикса -->
  <include file="$(find youbot_controller)/launch/arm_controller.launch"/>
  <include file="$(find youbot_controller)/launch/gripper_controller.launch"/>

  <!-- velocity_controllers для колёс (наши) -->
  <rosparam file="$(find youbot_mecanum_controller)/config/velocity_controllers.yaml" command="load"/>
  
  <!-- Загрузка PID для gazebo_ros_control -->
  <rosparam file="$(find youbot_mecanum_controller)/config/gazebo_pid_gains.yaml" command="load"/>

  <!-- Запуск контроллеров скорости колёс -->
  <node name="controller_spawner_wheels" pkg="controller_manager" type="spawner"
        args="
          wheel_joint_fl_velocity_controller
          wheel_joint_fr_velocity_controller
          wheel_joint_bl_velocity_controller
          wheel_joint_br_velocity_controller
        " output="screen"/>

  <!-- Наш mecanum_controller (база + одометрия) -->
  <node name="mecanum_controller" pkg="youbot_mecanum_controller" type="mecanum_controller.py" output="screen"/>

  <!-- robot_state_publisher -->
  <node pkg="robot_state_publisher" type="robot_state_publisher" name="robot_state_publisher">
    <param name="publish_frequency" type="double" value="50.0"/>
  </node>
</launch>